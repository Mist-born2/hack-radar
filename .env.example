# WhatsApp group targeting (ID takes precedence over name)
WHATSAPP_GROUP_ID=
WHATSAPP_GROUP_NAME=HackathonRadar

# Scanning schedule (cron expression, default every 6 hours)
SCAN_CRON=0 */6 * * *

# Run a scan immediately on startup after WhatsApp is ready
SCAN_ON_START=true

# Dry-run mode: log messages instead of sending to WhatsApp
DRY_RUN=false

# Maximum alerts to send per scan cycle
MAX_ALERTS_PER_SCAN=10

# Data directory for SQLite DB and WhatsApp session
DATA_DIR=./data

# Log level: debug, info, warn, error
LOG_LEVEL=info

# --- X/Twitter Scanner ---
# Comma-separated Nitter instances to use for X search.
# Leave empty to use built-in defaults. Instances rotate if one is down.
NITTER_INSTANCES=

# Comma-separated custom X search queries. Leave empty for defaults:
# hackathon, bounty, build competition, grant, $prize pool, win $,
# superteam, dorahacks, web3 hackathon, solana bounty, ai hackathon prize
X_SEARCH_QUERIES=
